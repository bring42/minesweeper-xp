# .gitignore

# Large binaries — never commit these directly
disk.img
*.img.bak
autorun.img

# Boxedwine files downloaded by scripts/prepare.sh at CI time
public/boxedwine.js
public/boxedwine.wasm
public/boxedwine-shell.js
public/boxedwine.css
public/winmine.zip

# Chunks and metadata generated by prepare.sh
public/chunks/

# Old v86 files (no longer used)
public/libv86.js
public/v86.wasm
public/seabios.bin
public/vgabios.bin

# Extracted exe (re-extractable from minesweeperxp/minesweeper.zip)
winmine.exe

# Wrangler cache
.wrangler/
.AppleDouble

# Node (not used but just in case)
node_modules/
